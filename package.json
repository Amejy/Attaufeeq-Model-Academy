{
  "name": "attaufiqschools-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bash ./scripts/dev-full.sh",
    "dev:web": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "build": "vite build",
    "lint": "eslint --cache \"src/**/*.{js,jsx}\" \"backend/**/*.{js,mjs}\" \"tests/**/*.{js,mjs}\" \"scripts/**/*.{js,mjs}\" \"*.config.js\"",
    "preview": "vite preview",
    "test:ui": "PLAYWRIGHT_BROWSERS_PATH=./.cache/ms-playwright playwright test",
    "test:ui:install": "PLAYWRIGHT_BROWSERS_PATH=./.cache/ms-playwright playwright install chromium",
    "test:ui:all": "bash ./scripts/ui-test.sh"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "papaparse": "^5.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.30.1",
    "read-excel-file": "^5.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1"
  }
}
